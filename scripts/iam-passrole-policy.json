{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPassEcsRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::160631388633:role/ecs-task-role",
        "arn:aws:iam::160631388633:role/ecsTaskExecutionRole"
      ],
      "Condition": {
        "StringEquals": { "iam:PassedToService": "ecs-tasks.amazonaws.com" }
      }
    }
  ]
}
